<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Formulir Kotak Surat - Umbrella Guild</title>
  <link rel="stylesheet" href="assets/style.css">
  
  <style>
    /* CSS tambahan khusus layout form agar tetap presisi */
    body { padding: 15px; display: flex; flex-direction: column; min-height: 100vh; }
    .container { flex-grow: 1; display: flex; flex-direction: column; }
    h3 { text-align: center; color: var(--color-primary); font-size: 16px; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px; }
    label { font-size: 11px; font-weight: bold; color: var(--text-muted); margin-bottom: 5px; text-transform: uppercase; display: block; }
    
    input, select, textarea { 
      width: 100%; padding: 12px; border-radius: 8px; background: #0f1419; 
      border: 1px solid var(--border-color); color: var(--text-bright); font-size: 14px; 
      margin-bottom: 15px; box-sizing: border-box; transition: 0.3s;
    }
    
    select { cursor: pointer; color: var(--color-primary); }
    .error-field { border-color: #ff4d4d !important; box-shadow: 0 0 5px #ff4d4d; }

    #wa-group { display: none; }
    textarea { flex-grow: 1; min-height: 120px; outline: none; resize: none; }

    #send-btn { 
      background: var(--color-primary); color: #000; border: none; padding: 15px; 
      border-radius: 25px; cursor: pointer; font-weight: bold; width: 100%; transition: 0.3s; 
    }
    #send-btn:disabled { background: #333; color: #666; cursor: not-allowed; }

    #success-screen { display: none; flex-direction: column; align-items: center; justify-content: center; flex-grow: 1; text-align: center; }
  </style>
</head>
<body>

<div class="container card-custom" style="padding: 20px;">
  <div id="form-wrapper">
    <h3 class="glow-effect">FORMULIR KOTAK SURAT</h3>
    
    <div style="display: flex; gap: 10px;">
      <div style="flex: 1;">
        <label>Nama / IGN</label>
        <input type="text" id="user-name" placeholder="Nama Anda...">
      </div>
      <div style="flex: 1;">
        <label>Kategori</label>
        <select id="surat-cat" onchange="toggleWA()">
          <option value="Umum">Umum</option>
          <option value="Permintaan">Ajukan Bergabung</option>
          <option value="Saran">Saran & Kritik</option>
        </select>
      </div>
    </div>

    <div id="wa-group">
      <label>Nomor WhatsApp</label>
      <input type="tel" id="wa-num" placeholder="Contoh: 0812xxx">
    </div>
    
    <label id="msg-label">Isi Pesan</label>
    <textarea id="surat-msg" placeholder="Detail pesan..."></textarea>
    
    <button id="send-btn" onclick="kirimSurat()">KIRIM SURAT</button>
  </div>

  <div id="success-screen">
    <div style="font-size: 60px; color: var(--color-primary);">✓</div>
    <h2 class="glow-effect">TERKIRIM</h2>
    <p style="color: var(--text-muted);">Pesan Anda sudah masuk ke database Markas Besar.</p>
  </div>
</div>

<script>
  // Ambil data lama agar user tidak perlu ketik ulang nama
  let myID = localStorage.getItem('UG_ID') || "UG-" + Math.floor(Math.random() * 1000000);
  if (!localStorage.getItem('UG_ID')) localStorage.setItem('UG_ID', myID);

  let myName = localStorage.getItem('UG_NAME');
  const nameInput = document.getElementById('user-name');

  if (myName) {
    nameInput.value = myName;
    nameInput.disabled = true;
    nameInput.style.opacity = "0.6";
  }

  function toggleWA() {
    const isPermintaan = document.getElementById('surat-cat').value === "Permintaan";
    document.getElementById('wa-group').style.display = isPermintaan ? "block" : "none";
    document.getElementById('msg-label').innerText = isPermintaan ? "Alasan Bergabung" : "Isi Pesan";
  }

  async function kirimSurat() {
    const fields = {
      name: document.getElementById('user-name'),
      msg: document.getElementById('surat-msg'),
      cat: document.getElementById('surat-cat'),
      wa: document.getElementById('wa-num')
    };

    // Reset error
    Object.values(fields).forEach(f => f.classList.remove('error-field'));
    let hasError = false;

    if (!fields.name.value.trim()) { fields.name.classList.add('error-field'); hasError = true; }
    if (!fields.msg.value.trim()) { fields.msg.classList.add('error-field'); hasError = true; }

    let finalMsg = fields.msg.value.trim();
    if (fields.cat.value === "Permintaan") {
      const waVal = fields.wa.value.trim();
      if (!/^(08|628)\d{8,13}$/.test(waVal)) {
        fields.wa.classList.add('error-field');
        hasError = true;
      }
      finalMsg = "WA: " + waVal + "\n---\n" + finalMsg;
    }

    if (hasError) return;

    const btn = document.getElementById('send-btn');
    btn.disabled = true;
    btn.innerText = "MENGIRIM...";

    // --- BAGIAN PENGIRIMAN KE ENGINE ---
    const urlEngine = "URL_ENGINE_A_ABANG_DISINI"; 

    const payload = {
      method: "handleSubmitSurat", // Meniru nama fungsi lama
      guest_id: myID,
      guest_name: fields.name.value.trim(),
      category: fields.cat.value,
      message: finalMsg
    };

    try {
      // Gunakan Fetch dengan no-cors agar bebas bentrok akun
      await fetch(urlEngine, {
        method: 'POST',
        mode: 'no-cors',
        body: JSON.stringify(payload)
      });

      if (!localStorage.getItem('UG_NAME')) localStorage.setItem('UG_NAME', fields.name.value.trim());
      
      document.getElementById('form-wrapper').style.display = 'none';
      document.getElementById('success-screen').style.display = 'flex';
    } catch (e) {
      alert("Gagal kirim. Cek koneksi!");
      btn.disabled = false;
      btn.innerText = "KIRIM SURAT";
    }
  }
</script>
</body>
</html>
